{
  "version": 2,
  "builds": [
    {
      "src": "api/telegram.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/telegram",
      "dest": "/api/telegram.ts"
    },
    {
      "src": "/",
      "dest": "/api/telegram.ts"
    }
  ],
  "functions": {
    "api/telegram.ts": {
      "maxDuration": 60
    }
  }
}
