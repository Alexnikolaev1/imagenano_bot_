TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Cloudflare Workers AI (image generation via Flux Schnell — free tier)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Text-to-image (default: flux-1-schnell — cheapest on free tier)
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Photo edit + /variation (default: flux-2-klein-4b — same API token)
# Alternatives: flux-2-klein-9b, flux-2-dev (higher quality, more neurons)
CLOUDFLARE_EDIT_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-4b

# Optional: Google AI Studio key — ONLY used to enhance short prompts (text model).
# Leave empty to disable prompt enhancement. Image generation does NOT use Google.
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
ENHANCE_PROMPTS=true

# Optional: Admin Telegram user ID for error notifications
ADMIN_CHAT_ID=your_telegram_user_id

# Optional: Max requests per user per day (default: 10)
MAX_REQUESTS_PER_DAY=10

# Optional: Default UI language when Telegram locale is unknown (ru | en)
DEFAULT_LANG=ru

# --- Video MP4 via Hugging Face Space (/video) — recommended ---
# LTX-Video on ZeroGPU: https://huggingface.co/spaces/alex555196/videobot
# If HUGGINGFACE_TOKEN is set, alex555196/videobot is used automatically (override with HF_VIDEO_SPACE)
# HUGGINGFACE_TOKEN=hf_...   (same token as /music)
# HF_VIDEO_SPACE=alex555196/videobot
# HF_VIDEO_TIMEOUT_MS=600000
# HF_VIDEO_POLL_INTERVAL_MS=5000
# HF_VIDEO_POLL_FETCH_MS=25000
# HF_VIDEO_MAX_POLL_ATTEMPTS=60
# HF_VIDEO_WIDTH=768
# HF_VIDEO_HEIGHT=448
# HF_VIDEO_FRAMES=49
# MAX_HF_VIDEO_REQUESTS_PER_DAY=5
# HF_VIDEO_ENABLED=true

# --- Video MP4 via Google Colab + ngrok (/video fallback) ---
# Colab is OFF unless COLAB_VIDEO_ENABLED=true (stale VIDEO_API is ignored otherwise)
# VIDEO_API=https://xxxx.ngrok-free.app/generate_video/
# VIDEO_API_TIMEOUT_MS=600000
# MAX_COLAB_VIDEO_REQUESTS_PER_DAY=5
# COLAB_VIDEO_ENABLED=true

# --- Video GIF via Cloudflare (/videogif) — free ---
# Only CLOUDFLARE_* keys needed. 10 clips per day by default.
# VIDEO_GIF_FRAME_DELAY_MS=130
# VIDEO_GIF_CROSSFADE_STEPS=6
# MAX_VIDEO_GIF_REQUESTS_PER_DAY=10
# MAX_VIDEO_REQUESTS_PER_DAY=10
# VIDEO_GIF_ENABLED=true

# --- Music (/music command) — Hugging Face MusicGen (recommended) ---
# 1. huggingface.co → Settings → Access Tokens → New (Read)
# 2. Add to Vercel:
# HUGGINGFACE_TOKEN=hf_...
# HUGGINGFACE_MUSIC_MODEL=facebook/musicgen-small
# MAX_MUSIC_REQUESTS_PER_DAY=5
# HF_MUSIC_MAX_RETRIES=4
# HF_MUSIC_RETRY_DELAY_MS=15000
# HF_MUSIC_TIMEOUT_MS=120000
# MUSIC_ENABLED=true

# Optional fallback: ModelScope (needs China Aliyun bind — not International)
# MUSIC_PROVIDER=modelscope
# MODELSCOPE_API_TOKEN=ms-...

# Set automatically by Vercel
# VERCEL_URL=your-project.vercel.app
