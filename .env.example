TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Cloudflare Workers AI (image generation via Flux Schnell — free tier)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Optional: override the image model (default: @cf/black-forest-labs/flux-1-schnell)
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Optional: Google AI Studio key — ONLY used to enhance short prompts (text model).
# Leave empty to disable prompt enhancement. Image generation does NOT use Google.
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
ENHANCE_PROMPTS=true

# Optional: Admin Telegram user ID for error notifications
ADMIN_CHAT_ID=your_telegram_user_id

# Optional: Max requests per user per day (default: 10)
MAX_REQUESTS_PER_DAY=10

# Optional: Default UI language when Telegram locale is unknown (ru | en)
DEFAULT_LANG=ru

# Set automatically by Vercel
# VERCEL_URL=your-project.vercel.app
