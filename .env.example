TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Cloudflare Workers AI (image generation via Flux Schnell — free tier)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Text-to-image (default: flux-1-schnell — cheapest on free tier)
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Photo edit + /variation (default: flux-2-klein-4b — same API token)
# Alternatives: flux-2-klein-9b, flux-2-dev (higher quality, more neurons)
CLOUDFLARE_EDIT_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-4b

# Optional: Google AI Studio key — ONLY used to enhance short prompts (text model).
# Leave empty to disable prompt enhancement. Image generation does NOT use Google.
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
ENHANCE_PROMPTS=true

# Optional: Admin Telegram user ID for error notifications
ADMIN_CHAT_ID=your_telegram_user_id

# Optional: Max requests per user per day (default: 10)
MAX_REQUESTS_PER_DAY=10

# Optional: Default UI language when Telegram locale is unknown (ru | en)
DEFAULT_LANG=ru

# --- Video (/video command) ---
# Default: cloudflare_gif — 2-frame looping GIF on free Cloudflare neurons (~5/day/user)
# VIDEO_PROVIDER=cloudflare_gif

# With ms- token: tries ModelScope mp4 first, falls back to GIF (VIDEO_FALLBACK=false to disable)
# MODELSCOPE_API_TOKEN=

# ModelScope video models (comma-separated fallbacks)
# POST https://api-inference.modelscope.cn/v1/videos/generations
# MODELSCOPE_T2V_MODEL=Wan-AI/Wan2.2-T2V-A14B-Diffusers,Wan-AI/Wan2.1-T2V-1.3B-Diffusers
# MODELSCOPE_I2V_MODEL=Wan-AI/Wan2.2-I2V-A14B-Diffusers,Wan-AI/Wan2.1-I2V-14B-720P
# MODELSCOPE_API_BASE=https://api-inference.modelscope.cn/v1

# Single-frame still (cheaper): VIDEO_PROVIDER=cloudflare_preview
# Paid Wan (per second): VIDEO_PROVIDER=dashscope + DASHSCOPE_API_KEY

# VIDEO_GIF_FRAME_DELAY_MS=900
# VIDEO_FALLBACK=false
# VIDEO_ENABLED=true
# MAX_VIDEO_REQUESTS_PER_DAY=5
# VIDEO_MAX_WAIT_MS=280000

# --- Music (/music command) — ModelScope MusicGen-Small (free with ms- token) ---
# Requires MODELSCOPE_API_TOKEN (same token as video)
# POST https://api-inference.modelscope.cn/v1/images/generations
# MODELSCOPE_MUSIC_MODEL=AI-ModelScope/musicgen-small,facebook/musicgen-small
# MAX_MUSIC_REQUESTS_PER_DAY=5
# MUSIC_POLL_INTERVAL_MS=3000
# MUSIC_MAX_WAIT_MS=120000
# MUSIC_ENABLED=true

# Set automatically by Vercel
# VERCEL_URL=your-project.vercel.app
